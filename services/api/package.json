{
  "name": "@baraticimo/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma --schema ../../infra/prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/trpc-server": "^0.3.4",
    "@prisma/client": "^5.22.0",
    "@baraticimo/types": "workspace:*",
    "@trpc/server": "^11.0.0-rc.638",
    "hono": "^4.6.10",
    "ioredis": "^5.4.1",
    "meilisearch": "^0.45.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
