{
  "name": "baraticimo",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @baraticimo/api prisma generate",
    "db:migrate": "pnpm --filter @baraticimo/api prisma migrate dev",
    "db:seed": "pnpm --filter @baraticimo/api db:seed",
    "scrape:jumbo": "pnpm --filter @baraticimo/scrapers scrape:jumbo"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "5.22.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  }
}
