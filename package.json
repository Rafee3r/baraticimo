{
  "name": "precios-chile",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @precios/api prisma generate",
    "db:migrate": "pnpm --filter @precios/api prisma migrate dev",
    "db:seed": "pnpm --filter @precios/api db:seed",
    "scrape:jumbo": "pnpm --filter @precios/scrapers scrape:jumbo"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
